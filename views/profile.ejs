<h1>Recent GitHub Activity</h1>

<% if (summary) { %>
  <section id="ai-summary" style="margin-bottom: 20px;">
    <h2>AI Summary</h2>
    <p style="font-style: italic; color: #555;"><%= summary %></p>
  </section>
<% } %>

<% if (commits && commits.length > 0) { %>
  <ul>
    <% commits.slice(0,5).forEach(commit => { %>
      <li style="margin-bottom: 10px;">
        <strong><%= commit.message %></strong>
        <br>
        <small><%= new Date(commit.date).toLocaleString() %></small>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p>No recent activity found.</p>
<% } %>

<!-- 🔥 DEV SUMMARY -->
<% if (devSummary) { %>
  <section style="margin-bottom: 20px;">
    <h2>Developer Profile</h2>
    <p style="color: #333; font-weight: 500;"><%= devSummary %></p>
  </section>
<% } else { %>
  <p>Developer profile not generated yet.</p>
<% } %>

<!-- 🔥 TOP PROJECTS SECTION -->
<% if (projects && projects.length > 0) { %>
  <section style="margin-top: 30px;">
    <h2>Top Projects</h2>

    <% projects.forEach(p => { %>
      <div style="margin-bottom: 15px;">
        <strong><%= p.name %></strong>
        <p><%= p.description %></p>

        <% if (p.tech && p.tech.length > 0) { %>
          <small>Tech: <%= p.tech.join(", ") %></small>
        <% } %>
      </div>
    <% }) %>

  </section>
<% } else { %>
  <p style="margin-top: 20px;">No projects generated yet.</p>
<% } %>